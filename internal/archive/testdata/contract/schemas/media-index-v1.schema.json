{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Susurrium/PkuHoleArchiveSpec/spec/v2/media-index-v1.schema.json",
  "title": "PkuHole media extension v1 index",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["ownerType", "ownerId", "variant", "status"],
    "properties": {
      "ownerType": { "enum": ["post", "comment"] },
      "ownerId": { "type": "integer", "minimum": 1 },
      "remoteId": { "type": "string" },
      "remoteUrl": { "type": "string" },
      "variant": { "type": "string", "minLength": 1 },
      "path": { "type": "string", "pattern": "^media/[A-Fa-f0-9]{64}(?:\\.[A-Za-z0-9]+)?$" },
      "mimeType": { "type": "string" },
      "size": { "type": "integer", "minimum": 0 },
      "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
      "width": { "type": "integer", "minimum": 0 },
      "height": { "type": "integer", "minimum": 0 },
      "status": { "enum": ["available", "missing"] }
    },
    "additionalProperties": true
  }
}
