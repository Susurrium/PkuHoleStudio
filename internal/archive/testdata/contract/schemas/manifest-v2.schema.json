{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Susurrium/PkuHoleArchiveSpec/spec/v2/manifest-v2.schema.json",
  "title": "PkuHole Archive v2 manifest.json",
  "type": "object",
  "required": ["schemaVersion", "toolVersion", "runId", "exportedAt", "scope", "complete", "counts", "errors"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "specVersion": { "type": "string", "pattern": "^2\\.[0-9]+\\.[0-9]+$" },
    "toolVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
    "producer": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "version": { "type": "string", "minLength": 1, "maxLength": 80 }
      },
      "additionalProperties": false
    },
    "runId": { "type": "string", "minLength": 1, "maxLength": 160 },
    "exportedAt": { "type": "string", "format": "date-time" },
    "scope": { "$ref": "#/$defs/scope" },
    "complete": { "type": "boolean" },
    "counts": {
      "type": "object",
      "properties": {
        "expectedHoles": { "type": ["integer", "null"], "minimum": 0 },
        "exportedHoles": { "type": "integer", "minimum": 0 },
        "comments": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "media": { "type": "integer", "minimum": 0 },
        "missingMedia": { "type": "integer", "minimum": 0 },
        "localTags": { "type": "integer", "minimum": 0 },
        "localNotes": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "dateRange": {
      "type": ["object", "null"],
      "properties": {
        "earliest": { "type": "string", "format": "date-time" },
        "latest": { "type": "string", "format": "date-time" }
      },
      "required": ["earliest", "latest"],
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extensions": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$" },
      "additionalProperties": {
        "type": "object",
        "required": ["version"],
        "properties": {
          "version": { "type": "integer", "minimum": 1 },
          "required": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "requiredExtensions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "selector": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "minLength": 1, "maxLength": 80 },
        "bookmarkId": { "type": ["string", "null"] },
        "pids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]{5,7}$" },
          "uniqueItems": true
        },
        "startDate": { "type": ["string", "null"], "format": "date" },
        "endDate": { "type": ["string", "null"], "format": "date" }
      },
      "additionalProperties": true
    },
    "scope": {
      "oneOf": [
        { "$ref": "#/$defs/selector" },
        {
          "type": "object",
          "required": ["scope"],
          "properties": { "scope": { "$ref": "#/$defs/selector" } },
          "additionalProperties": true
        }
      ]
    }
  },
  "additionalProperties": true
}
